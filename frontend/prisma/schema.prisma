generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── NextAuth required tables ─────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  // Newsletter
  newsletterEnabled    Boolean   @default(true)
  newsletterLastSentAt DateTime?

  // Subscription tier
  tier                 String    @default("free")   // "free" | "pro" | "kancelaria"
  tierExpiresAt        DateTime?

  // Stripe
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?

  accounts   Account[]
  sessions   Session[]
  usageLogs  UsageLog[]
  queryLogs  QueryLog[]
  apiTokens        ApiToken[]
  alerts           LegalAlert[]
  privateDocuments PrivateDocument[]
  widgetConfig     WidgetConfig?
  registrySubs     RegistrySubscription[]
  expertRequests   ExpertRequest[]        @relation("Requester")
  expertResponses  ExpertRequest[]        @relation("Responder")
}

// ── Legal Diff alerts ─────────────────────────────────────────────────────────

model LegalChange {
  id          String   @id @default(cuid())
  detectedAt  DateTime @default(now())
  actId       String
  title       String
  sourceType  String
  year        Int?
  summary     String   // 1-2 zdania o zmianie (generowane przez LLM)
  chunkText   String   // fragment nowego/zmienionego przepisu
  url         String?

  alerts LegalAlert[]

  @@index([actId])
  @@index([detectedAt(sort: Desc)])
  @@index([sourceType])
}

model LegalAlert {
  id          String    @id @default(cuid())
  userId      String
  changeId    String
  similarity  Float     // cosine similarity pytania użytkownika do zmiany
  question    String    // pytanie które wygenerowało subskrypcję
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  change LegalChange @relation(fields: [changeId], references: [id], onDelete: Cascade)

  @@unique([userId, changeId])
  @@index([userId, readAt])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Query history ─────────────────────────────────────────────────────────────

model QueryLog {
  id            String   @id @default(cuid())
  userId        String
  createdAt     DateTime @default(now())
  question      String
  answer        String
  sources       String   // JSON blob: SourceDocument[]
  modelUsed     String
  retrievalUsed Boolean  @default(true)

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedback Feedback?

  @@index([userId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

// ── User feedback (thumbs up/down) ───────────────────────────────────────────

model Feedback {
  id          String   @id @default(cuid())
  queryLogId  String   @unique
  userId      String?  // nullable — anonymous feedback allowed
  rating      Int      // +1 (thumbup) or -1 (thumbdown)
  comment     String?  // optional free-text note
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  queryLog QueryLog @relation(fields: [queryLogId], references: [id], onDelete: Cascade)

  @@index([rating])
  @@index([createdAt(sort: Desc)])
  @@index([userId])
}

// ── API tokens (plan kancelaria) ─────────────────────────────────────────────

model ApiToken {
  id          String    @id @default(cuid())
  userId      String
  name        String                        // etykieta nadana przez usera
  tokenHash   String    @unique             // SHA-256 hex — nigdy nie przechowujemy plaintextu
  prefix      String                        // pierwsze 8 znaków tokenu — do identyfikacji w UI
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  requestCount Int      @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ── Private documents (per-user RAG) ─────────────────────────────────────────

model PrivateDocument {
  id           String   @id @default(cuid())
  userId       String
  filename     String
  mimeType     String
  sizeBytes    Int
  status       String   @default("processing") // "processing"|"ready"|"error"
  errorMsg     String?
  chunkCount   Int      @default(0)
  uploadedAt   DateTime @default(now())
  processedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([uploadedAt(sort: Desc)])
}

// ── Shareable reports ─────────────────────────────────────────────────────────

model SharedReport {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  question  String
  answer    String
  sources   String   // JSON
  modelUsed String
  createdAt DateTime @default(now())
  expiresAt DateTime?

  @@index([token])
}

// ── Embeddable widget (plan kancelaria) ───────────────────────────────────────

model WidgetConfig {
  id             String   @id @default(cuid())
  userId         String   @unique          // one widget per user
  token          String   @unique          // public embed token (non-secret)
  enabled        Boolean  @default(true)
  title          String   @default("Asystent prawny")
  welcomeMsg     String   @default("Cześć! Jestem asystentem prawnym. W czym mogę pomóc?")
  accentColor    String   @default("#2563eb")
  logoUrl        String?
  allowedDomains String   @default("*")   // comma-sep or "*"
  requestCount   Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Expert marketplace ────────────────────────────────────────────────────────

model ExpertRequest {
  id           String    @id @default(cuid())
  requesterId  String
  question     String
  context      String?   // AI answer context (optional, user can attach)
  status       String    @default("open")  // open | answered | closed
  expertId     String?
  response     String?
  respondedAt  DateTime?
  createdAt    DateTime  @default(now())

  requester User  @relation("Requester", fields: [requesterId], references: [id], onDelete: Cascade)
  expert    User? @relation("Responder", fields: [expertId],    references: [id], onDelete: SetNull)

  @@index([status, createdAt(sort: Desc)])
  @@index([requesterId])
}

// ── Registry subscriptions ────────────────────────────────────────────────────

model RegistrySubscription {
  id        String   @id @default(cuid())
  userId    String
  actId     String   // ISAP actId / identifier
  title     String   // display name of the act
  url       String?  // ISAP source URL
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, actId])
  @@index([actId])
  @@index([userId])
}

// ── Usage tracking ────────────────────────────────────────────────────────────

model UsageLog {
  id        String   @id @default(cuid())
  userId    String
  date      String   // YYYY-MM-DD — partition key for daily counts
  count     Int      @default(0)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}
