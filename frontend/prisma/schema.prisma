generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ── NextAuth required tables ─────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  // Subscription tier
  tier                 String    @default("free")   // "free" | "pro" | "kancelaria"
  tierExpiresAt        DateTime?

  // Stripe
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?

  accounts   Account[]
  sessions   Session[]
  usageLogs  UsageLog[]
  queryLogs  QueryLog[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Query history ─────────────────────────────────────────────────────────────

model QueryLog {
  id            String   @id @default(cuid())
  userId        String
  createdAt     DateTime @default(now())
  question      String
  answer        String
  sources       String   // JSON blob: SourceDocument[]
  modelUsed     String
  retrievalUsed Boolean  @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

// ── Usage tracking ────────────────────────────────────────────────────────────

model UsageLog {
  id        String   @id @default(cuid())
  userId    String
  date      String   // YYYY-MM-DD — partition key for daily counts
  count     Int      @default(0)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}
