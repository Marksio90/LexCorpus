FROM python:3.11-slim
WORKDIR /app

COPY pyproject.toml .
RUN pip install --no-cache-dir \
    httpx \
    tqdm \
    numpy \
    sentence-transformers \
    "qdrant-client[fastembed]" \
    fastembed \
    fastapi \
    "uvicorn[standard]" \
    python-dotenv \
    openai \
    beautifulsoup4 \
    lxml \
    pydantic \
    pymupdf \
    "apscheduler>=3.10" \
    redis \
    asyncpg \
    "celery[redis]" \
    psycopg2-binary

COPY . .

EXPOSE 8000

# Use /ping for Docker healthcheck (lightweight, no model loading)
# /health is available for manual checks but triggers lazy model init
HEALTHCHECK --interval=30s --timeout=10s --retries=5 --start-period=300s \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8000/ping')"

CMD ["uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8000"]
