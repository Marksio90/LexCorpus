FROM python:3.11-slim
WORKDIR /app

COPY pyproject.toml .
RUN pip install --no-cache-dir \
    httpx \
    tqdm \
    datasets \
    transformers \
    peft \
    sentence-transformers \
    qdrant-client \
    fastapi \
    uvicorn[standard] \
    python-dotenv \
    openai \
    beautifulsoup4 \
    lxml \
    pydantic

COPY . .

EXPOSE 8000
CMD ["uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8000"]
