FROM python:3.11-slim
WORKDIR /app

COPY pyproject.toml .
RUN pip install --no-cache-dir \
    httpx \
    tqdm \
    numpy \
    sentence-transformers \
    "qdrant-client[fastembed]" \
    fastembed \
    fastapi \
    "uvicorn[standard]" \
    python-dotenv \
    openai \
    beautifulsoup4 \
    lxml \
    pydantic \
    pymupdf

COPY . .

EXPOSE 8000
CMD ["uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8000"]
