# Copy to .env and fill in values:  cp .env.example .env

# ── Domain (production) ────────────────────────────────────────────────────────
DOMAIN=lexcorpus.app

# ── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Embedding / RAG ────────────────────────────────────────────────────────────
# Faster (CPU-friendly):
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
# Better quality (GPU recommended):
# EMBEDDING_MODEL=sdadas/mmlw-retrieval-roberta-large

RERANK_ENABLED=true
RERANK_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
EXPAND_ENABLED=true
HYDE_ENABLED=true

# ── Qdrant ─────────────────────────────────────────────────────────────────────
QDRANT_COLLECTION=lexcorpus

# ── Data pipeline — ISAP (legislation) ────────────────────────────────────────
FETCH_YEAR_FROM=2024
FETCH_YEAR_TO=2025

# ── Data pipeline — SAOS (court decisions) ────────────────────────────────────
SAOS_ENABLED=true
SAOS_YEAR_FROM=2023
SAOS_YEAR_TO=2025
# ~100k judgments/year — first run takes ~2h, subsequent runs are incremental

# ── EUR-Lex (prawo UE — rozporządzenia i dyrektywy) ───────────────────────────
EURLEX_ENABLED=true
EURLEX_YEAR_FROM=2020
EURLEX_YEAR_TO=2025
EURLEX_MAX_ACTS=2000
# Types: regulation,directive,decision
EURLEX_TYPES=regulation,directive

# ── NextAuth ───────────────────────────────────────────────────────────────────
# WYMAGANE — wygeneruj: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://lexcorpus.app
NEXT_PUBLIC_API_URL=https://lexcorpus.app/api

# ── Auto-sync (weekly SAOS update) ────────────────────────────────────────────
SYNC_ENABLED=true
# Cron expression (default: Sunday 03:00 Europe/Warsaw)
SYNC_CRON=0 3 * * 0
# How many days back to fetch on each sync (overlap for safety)
SYNC_SINCE_DAYS=8

# ── Security / rate limiting ───────────────────────────────────────────────────
# CORS: comma-separated allowed origins (* = allow all, use specific domain in prod)
ALLOWED_ORIGINS=https://lexcorpus.app
# Rate limit: max requests per IP per window (seconds)
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW=60

# ── Access control ─────────────────────────────────────────────────────────────
# Leave empty to allow anyone; comma-separated to restrict admin panel
ADMIN_EMAILS=you@example.com

# ── Email (magic link auth + newsletter) ──────────────────────────────────────
EMAIL_SERVER_HOST=smtp.gmail.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=you@gmail.com
EMAIL_SERVER_PASSWORD=your-app-password
EMAIL_FROM=noreply@lexcorpus.app

# Internal secret for API→frontend newsletter trigger
# WYMAGANE — wygeneruj: openssl rand -hex 32
NEWSLETTER_INTERNAL_SECRET=
# Cron schedule for newsletter (default: Monday 08:00 Warsaw)
NEWSLETTER_CRON=0 8 * * 1

# ── Stripe (płatności) ─────────────────────────────────────────────────────────
# Klucze ze Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook secret: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs ze Stripe Dashboard → Products
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_KANCELARIA=price_...

# ── Baza danych ────────────────────────────────────────────────────────────────
DATABASE_PATH=/app/prisma/prod.db

# ── Wewnętrzna komunikacja kontenerów (Docker) ────────────────────────────────
# URL FastAPI widoczny wewnątrz sieci Docker (nie eksponowany na zewnątrz)
INTERNAL_API_URL=http://api:8000

# ── Qdrant ─────────────────────────────────────────────────────────────────────
# Lokalny storage Qdrant (dla trybu embedded / bez osobnego kontenera)
QDRANT_PATH=data/qdrant
# Opcjonalne: zewnętrzny serwer Qdrant
# QDRANT_URL=http://qdrant:6333
# QDRANT_API_KEY=

# ── Lokalny model (opcjonalnie — zamiast OpenAI) ──────────────────────────────
# Ścieżka do wytrenowanego modelu Bielik po fine-tuningu
# LOCAL_MODEL_PATH=./output/lexcorpus-merged

# ── Prywatne dokumenty użytkowników (Private RAG) ────────────────────────────
PRIVATE_DOCS_DIR=/app/private_docs

# ── UI ────────────────────────────────────────────────────────────────────────
# Etykieta modelu wyświetlana w interfejsie (np. "GPT-4o-mini" lub "Bielik-7B")
NEXT_PUBLIC_MODEL_LABEL=GPT-4o-mini
