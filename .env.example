# Skopiuj jako .env i uzupełnij wartości
# cp .env.example .env

# OpenAI API (wymagane do generowania odpowiedzi)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Qdrant — domyślnie plikowy (data/qdrant/), zmień na serwer jeśli używasz dockera
QDRANT_PATH=data/qdrant
# QDRANT_PATH=http://localhost:6333

QDRANT_COLLECTION=lexcorpus

# Opcjonalnie: lokalny model po fine-tuningu
# LOCAL_MODEL_PATH=./output/lexcorpus-bielik

# Opcjonalnie: inny model embeddingów
# EMBEDDING_MODEL=sdadas/mmlw-retrieval-roberta-large
