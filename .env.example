# Copy to .env and fill in values:  cp .env.example .env

# ── Domain (production) ────────────────────────────────────────────────────────
DOMAIN=lexcorpus.example.com

# ── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Embedding / RAG ────────────────────────────────────────────────────────────
# Faster (CPU-friendly):
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
# Better quality (GPU recommended):
# EMBEDDING_MODEL=sdadas/mmlw-retrieval-roberta-large

RERANK_ENABLED=true
RERANK_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
EXPAND_ENABLED=true

# ── Qdrant ─────────────────────────────────────────────────────────────────────
QDRANT_COLLECTION=lexcorpus

# ── Data pipeline — ISAP (legislation) ────────────────────────────────────────
FETCH_YEAR_FROM=2024
FETCH_YEAR_TO=2025

# ── Data pipeline — SAOS (court decisions) ────────────────────────────────────
SAOS_ENABLED=true
SAOS_YEAR_FROM=2023
SAOS_YEAR_TO=2025
# ~100k judgments/year — first run takes ~2h, subsequent runs are incremental

# ── NextAuth ───────────────────────────────────────────────────────────────────
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=https://lexcorpus.example.com
NEXT_PUBLIC_API_URL=https://lexcorpus.example.com/api

# ── Auto-sync (weekly SAOS update) ────────────────────────────────────────────
SYNC_ENABLED=true
# Cron expression (default: Sunday 03:00 Europe/Warsaw)
SYNC_CRON=0 3 * * 0
# How many days back to fetch on each sync (overlap for safety)
SYNC_SINCE_DAYS=8

# ── Security / rate limiting ───────────────────────────────────────────────────
# CORS: comma-separated allowed origins (* = allow all, use specific domain in prod)
ALLOWED_ORIGINS=https://lexcorpus.example.com
# Rate limit: max requests per IP per window (seconds)
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW=60

# ── Access control ─────────────────────────────────────────────────────────────
# Leave empty to allow anyone; comma-separated to restrict admin panel
ADMIN_EMAILS=you@example.com

# ── Email (magic link auth) ────────────────────────────────────────────────────
EMAIL_SERVER_HOST=smtp.gmail.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=you@gmail.com
EMAIL_SERVER_PASSWORD=your-app-password
EMAIL_FROM=noreply@lexcorpus.example.com
