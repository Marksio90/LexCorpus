# Copy to .env and fill in values:  cp .env.example .env

# ── Domain (production) ────────────────────────────────────────────────────────
DOMAIN=lexcorpus.app

# ── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Embedding / RAG ────────────────────────────────────────────────────────────
# ── Dense embedding model ─────────────────────────────────────────────────────
# v2 (+2.25 NDCG vs v1, same 0.4B params, MIT license) — recommended default:
EMBEDDING_MODEL=sdadas/mmlw-retrieval-roberta-large-v2

# Best quality (8k context, handles full judgments, Gemini license — check terms):
# EMBEDDING_MODEL=sdadas/stella-pl-retrieval-8k

# Best quality/size tradeoff with 8k context (400M, MIT-like):
# EMBEDDING_MODEL=sdadas/stella-pl-retrieval-mini-8k

# Fastest CPU-friendly fallback (lower quality):
# EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# Query prefix for embedding model — MUST match the model used:
# mmlw-retrieval-roberta-large-v2 → "[query]: "
# stella-pl-retrieval-8k         → "Instruct: Given a web search query, retrieve relevant passages that answer the query.\nQuery: "
# paraphrase-multilingual-*      → ""  (no prefix)
EMBED_QUERY_PREFIX=[query]:

# ── Reranker ──────────────────────────────────────────────────────────────────
RERANK_ENABLED=true
# Polish legal reranker — PIRB NDCG@10: 62.65 (best Polish reranker available):
RERANK_MODEL=sdadas/polish-reranker-large-ranknet
# Multilingual fallback (self-hosted, covers Polish):
# RERANK_MODEL=BAAI/bge-reranker-v2-m3
# Original generic fallback:
# RERANK_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1

# ── Advanced RAG features ─────────────────────────────────────────────────────
EXPAND_ENABLED=true
HYDE_ENABLED=true

# CRAG (Corrective RAG): filter low-confidence retrieved chunks before LLM generation.
# Prevents the LLM from citing wrong statutes. Disable only for debugging.
CRAG_ENABLED=true
# Cross-encoder score threshold: chunks below this are dropped (tune empirically)
CRAG_LOW_THRESHOLD=-3.0

# Adaptive RAG: classify query complexity and route to appropriate retrieval strategy.
# TRIVIAL queries skip retrieval; COMPLEX queries get more candidates and expansions.
ADAPTIVE_RAG_ENABLED=true

# Contextual Retrieval: enrich chunks with LLM-generated context prefix at index time.
# Run scripts/generate_contextual_chunks.py once to enrich data/processed/chunks.jsonl.
# After enrichment, re-ingest (delete data/qdrant/.ingested and run docker compose up).
CONTEXTUAL_RETRIEVAL_ENABLED=false

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=lexcorpus
POSTGRES_PASSWORD=zmien-mnie-na-produkcji
POSTGRES_DB=lexcorpus
DATABASE_URL=postgresql://lexcorpus:zmien-mnie-na-produkcji@postgres:5432/lexcorpus

# ── Wewnętrzny sekret Next.js ↔ FastAPI ───────────────────────────────────────
# Wygeneruj: openssl rand -hex 32
INTERNAL_API_SECRET=wygeneruj-openssl-rand-hex-32
BACKEND_URL=http://api:8000

# ── Qdrant ─────────────────────────────────────────────────────────────────────
QDRANT_COLLECTION=lexcorpus

# ── Data pipeline — ISAP (legislation) ────────────────────────────────────────
# Production: use 2018-2025 for full coverage
FETCH_YEAR_FROM=2018
FETCH_YEAR_TO=2025

# ── Data pipeline — SAOS (court decisions) ────────────────────────────────────
SAOS_ENABLED=true
SAOS_YEAR_FROM=2018
SAOS_YEAR_TO=2025
# ~100k judgments/year — first run takes ~2h, subsequent runs are incremental

# ── EUR-Lex (prawo UE — rozporządzenia i dyrektywy) ───────────────────────────
EURLEX_ENABLED=true
EURLEX_YEAR_FROM=2020
EURLEX_YEAR_TO=2025
EURLEX_MAX_ACTS=5000
# Types: regulation,directive,decision
EURLEX_TYPES=regulation,directive

# ── Data pipeline — KIS (interpretacje indywidualne) ─────────────────────────
# ~50k+ interpretations/year from Krajowa Informacja Skarbowa (MF portal)
KIS_ENABLED=true
KIS_YEAR_FROM=2020
KIS_YEAR_TO=2025
# KIS_MAX_ITEMS=500      # cap for testing
KIS_DELAY=0.5            # seconds between requests (be polite to MF servers)
# KIS_API_URL=https://interpretacje.podatki.gov.pl  # override if portal moves

# ── Parent-child chunking ─────────────────────────────────────────────────────
# Set to true to use Small-to-Big retrieval (128-token children, 512-token parents).
# Improves retrieval precision. Requires full re-ingestion (delete data/qdrant/.ingested).
PARENT_CHILD_CHUNKING=false

# ── NextAuth ───────────────────────────────────────────────────────────────────
# WYMAGANE — wygeneruj: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://lexcorpus.app
NEXT_PUBLIC_API_URL=https://lexcorpus.app/api

# ── Auto-sync (weekly SAOS update) ────────────────────────────────────────────
SYNC_ENABLED=true
# Cron expression (default: Sunday 03:00 Europe/Warsaw)
SYNC_CRON=0 3 * * 0
# How many days back to fetch on each sync (overlap for safety)
SYNC_SINCE_DAYS=8

# ── Security / rate limiting ───────────────────────────────────────────────────
# CORS: comma-separated allowed origins (* = allow all, use specific domain in prod)
ALLOWED_ORIGINS=https://lexcorpus.app
# Rate limit: max requests per IP per window (seconds)
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW=60
# Redis URL dla rate limitingu (fallback do in-process gdy niedostępny)
REDIS_URL=redis://redis:6379/0
# Opcjonalne hasło Redis (zalecane w produkcji)
# REDIS_PASSWORD=zmien-mnie

# ── Access control ─────────────────────────────────────────────────────────────
# Leave empty to allow anyone; comma-separated to restrict admin panel
ADMIN_EMAILS=you@example.com

# ── Email (magic link auth + newsletter) ──────────────────────────────────────
# Resend (resend.com) — zalecany provider:
#   1. Zarejestruj się na resend.com (3 000 maili/mies. za darmo)
#   2. Domains → Add Domain → dodaj lexcorpus.pl (DNS TXT/MX)
#   3. API Keys → Create API Key → skopiuj re_...
#   USER zawsze = "resend", PASSWORD = Twój klucz API
EMAIL_SERVER_HOST=smtp.resend.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=resend
EMAIL_SERVER_PASSWORD=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@lexcorpus.pl

# Internal secret for API→frontend newsletter trigger
# WYMAGANE — wygeneruj: openssl rand -hex 32
NEWSLETTER_INTERNAL_SECRET=
# Cron schedule for newsletter (default: Monday 08:00 Warsaw)
NEWSLETTER_CRON=0 8 * * 1

# ── Stripe (płatności) ─────────────────────────────────────────────────────────
# Klucze ze Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook secret: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs ze Stripe Dashboard → Products
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_KANCELARIA=price_...

# ── Baza danych ────────────────────────────────────────────────────────────────
DATABASE_PATH=/app/prisma/prod.db

# ── Wewnętrzna komunikacja kontenerów (Docker) ────────────────────────────────
# URL FastAPI widoczny wewnątrz sieci Docker (nie eksponowany na zewnątrz)
INTERNAL_API_URL=http://api:8000

# ── Qdrant ─────────────────────────────────────────────────────────────────────
# Lokalny storage Qdrant (dla trybu embedded / bez osobnego kontenera)
QDRANT_PATH=data/qdrant
# Opcjonalne: zewnętrzny serwer Qdrant
# QDRANT_URL=http://qdrant:6333
# QDRANT_API_KEY=

# ── Lokalny model (opcjonalnie — zamiast OpenAI) ──────────────────────────────
# Ścieżka do wytrenowanego modelu Bielik po fine-tuningu
# LOCAL_MODEL_PATH=./output/lexcorpus-merged

# ── Prywatne dokumenty użytkowników (Private RAG) ────────────────────────────
PRIVATE_DOCS_DIR=/app/private_docs

# ── UI ────────────────────────────────────────────────────────────────────────
# Etykieta modelu wyświetlana w interfejsie (np. "GPT-4o-mini" lub "Bielik-7B")
NEXT_PUBLIC_MODEL_LABEL=GPT-4o-mini

# ── Monitoring (opcjonalnie) ───────────────────────────────────────────────────
# Sentry DSN — błędy trafiają do Sentry
# SENTRY_DSN=https://xxx@sentry.io/xxx
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx

# Backup
# BACKUP_DIR=/mnt/backups/lexcorpus
# KEEP_DAYS=14
